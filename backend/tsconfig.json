{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",

    "rootDir": "./src",
    "outDir": "./dist",

    "types": ["node"],
    "esModuleInterop": true,

    "strict": true,
    "jsx": "preserve",
    "skipLibCheck": true
  },
  "include": ["src"]
}